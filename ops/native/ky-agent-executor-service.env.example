# Install as /data/kyai_crm/config/ky-agent-executor-service.env with mode 0640,
# owner root and group ky-agent-executor.  Do not put AI provider secrets,
# CODEX_HOME, credential paths or child-process environment in this file.

KY_AGENT_EXECUTOR_SERVICE_HTTP_ADDR=127.0.0.1:18087

# This LOGIN is provisioned out of band and must be a member of the NOLOGIN
# ky_agent_executor_reader group only during P1.  It must not inherit writer or
# owner roles.
KY_AGENT_EXECUTOR_DATABASE_URL=postgresql://ky_agent_executor_shadow:change_me@127.0.0.1:5432/kyai_crm_tenant?sslmode=disable

# May equal the platform internal-service token, but is injected into this
# control-plane process through its dedicated environment file only.
KY_AGENT_EXECUTOR_INTERNAL_TOKEN=change_me_internal_service_token
