# Install as /data/kyai_crm/config/ky-agent-executor-service.env with mode 0640,
# owner root and group ky-agent-executor.  Do not put AI provider secrets,
# CODEX_HOME, credential paths or child-process environment in this file.

KY_AGENT_EXECUTOR_SERVICE_HTTP_ADDR=127.0.0.1:18087

# This LOGIN is provisioned out of band and must be a member of the NOLOGIN
# ky_agent_executor_reader group only during P1.  It must not inherit writer or
# owner roles.
KY_AGENT_EXECUTOR_DATABASE_URL=postgresql://ky_agent_executor_shadow:change_me@127.0.0.1:5432/kyai_crm_tenant?sslmode=disable

# May equal the platform internal-service token, but is injected into this
# control-plane process through its dedicated environment file only.
KY_AGENT_EXECUTOR_INTERNAL_TOKEN=change_me_internal_service_token

# P2A remains disabled until the reviewed writer-role cutover. Enabling it
# also requires every dependency below; startup fails closed when any is absent.
KY_AGENT_EXECUTOR_WRITE_ENABLED=false
# KY_AGENT_EXECUTOR_WRITER_DATABASE_URL=postgresql://ky_agent_executor_writer_login:change_me@127.0.0.1:5432/kyai_crm_tenant?sslmode=disable
# KY_AUTH_TOKEN_SECRET=change_me_auth_token_secret
# Use an independent, high-entropy value of at least 32 bytes. Never reuse the
# auth-token or internal-service secret; it deterministically rebuilds only the
# plaintext Desktop registration challenge from its persisted challengeId.
# KY_AGENT_EXECUTOR_DEVICE_CHALLENGE_SECRET=change_me_independent_64_byte_random_device_challenge_secret
# Use a second independent high-entropy value of at least 32 bytes. It derives
# only operation-confirmation challenge text.
# KY_AGENT_EXECUTOR_CONFIRMATION_CHALLENGE_SECRET=change_me_independent_64_byte_random_confirmation_challenge_secret
# A third independent high-entropy value of at least 32 bytes. Trusted-token
# nonces are deterministically derived only from this secret.
# KY_AGENT_EXECUTOR_TRUSTED_TOKEN_NONCE_SECRET=change_me_independent_64_byte_random_trusted_token_nonce_secret
# Raw 64-byte Ed25519 private key encoded as canonical base64url without
# padding. The service derives its verification key; never configure a public
# key independently or reuse any auth/challenge/internal secret.
# KY_AGENT_EXECUTOR_TRUSTED_TOKEN_KEY_ID=confirmation_key_1
# KY_AGENT_EXECUTOR_TRUSTED_TOKEN_PRIVATE_KEY=change_me_canonical_base64url_ed25519_private_key
# Strict JSON public-key ring (mode 0640, root:ky-agent-executor). It contains
# no private key. Write mode fails closed unless activeKid/public key matches
# the private key above and every signing/retirement window is valid.
# KY_AGENT_EXECUTOR_TRUSTED_TOKEN_KEYRING_FILE=/data/kyai_crm/config/ky-agent-executor-trusted-token-keyring.json
KY_MEMBERSHIP_SERVICE_URL=http://127.0.0.1:18083
KY_AGENT_EXECUTOR_CREDENTIAL_ROOT=/var/lib/aicrm-agent-executors
KY_AGENT_EXECUTOR_RUNTIME_BROKER_SOCKET=/run/aicrm-agent-runtime.sock
KY_CODEX_VERSION=0.144.1
