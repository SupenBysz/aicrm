{
  "name": "@ky/aicrm-desktop",
  "displayName": "AiCRM",
  "productName": "AiCRM",
  "appId": "com.kysion.aicrm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/start-dev.mjs dev",
    "build": "electron-vite build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:codex-executor-auth-safety": "node --test src/main/codex-executor-auth-safety.test.mjs",
    "test:codex-authorization-bridge-v2": "node --test src/main/codex-authorization-bridge-v2.test.mjs",
    "test:desktop-device-identity": "node --test src/main/desktop-device-identity.test.mjs",
    "test:desktop-device-registration": "node --test src/main/desktop-device-registration-client.test.mjs",
    "test:desktop-device-heartbeat": "node --test src/main/desktop-device-heartbeat-client.test.mjs",
    "test:desktop-device-trust-runtime": "node --test src/main/desktop-device-trust-runtime.test.mjs src/main/desktop-session-store.test.mjs",
    "test:controlled-window-release": "node --test src/main/controlled-window-release.test.mjs",
    "test:matrix-account-policy": "node --test src/main/matrix-account-script-policy.test.mjs",
    "test:matrix-account-session-vault": "node --test src/main/matrix-account-session-vault.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "node scripts/start-dev.mjs preview"
  },
  "dependencies": {
    "tar": "^7.5.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
