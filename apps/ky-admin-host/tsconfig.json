{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@ky/admin-core": ["../../packages/ky-admin-core/src/index.ts"],
      "@ky/plugin-access-management": ["../../plugins/ky-access-management/src/index.tsx"],
      "@ky/plugin-ai-configuration": ["../../plugins/ky-ai-configuration/src/index.tsx"],
      "@ky/plugin-audit-management": ["../../plugins/ky-audit-management/src/index.tsx"],
      "@ky/plugin-identity-management": ["../../plugins/ky-identity-management/src/index.tsx"],
      "@ky/plugin-notification": ["../../plugins/ky-notification/src/index.tsx"],
      "@ky/plugin-organization-management": ["../../plugins/ky-organization-management/src/index.tsx"],
      "@ky/plugin-system-settings": ["../../plugins/ky-system-settings/src/index.tsx"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "../../packages/ky-admin-core/src",
    "../../plugins/*/src"
  ]
}
